{
    "rules": {
        "Passengerjobs": {
            "$uid": {
                ".read": "auth != null && auth.uid == $uid",
                ".write": "auth != null && auth.uid == $uid",
                ".validate": "$uid != 'null'"
            }
        },
        "chat": {
            "$driverid": {
                ".read": true,
                ".write": true
            }
        },
        "chatMessages": {
            "$companyId": {
                ".read": "auth != null",
                ".write": "auth != null"
            }
        },
        "notification": {
            "$driverid": {
                ".validate": "$driverid!='null'",
                ".read": true,
                ".write": true
            }
        },
        "online": {
            ".read": true,
            ".write": "auth != null",
            "$companyid": {
                "$vehicleid": {
                    "$uid": {
                        ".write": "$uid === auth.uid"
                    }
                }
            }
        },
        "jobs": {
            ".read": "auth != null",
            ".write": "auth != null"
        },
        "links": {
            ".read": "auth != null",
            ".write": false
        },
        "tariffZones": {
            ".read": true,
            ".write": "auth != null"
        },
        "tariffs": {
            ".read": true,
            ".write": "auth != null"
        },
        "zones": {
            ".read": "auth != null",
            ".write": "auth != null"
        },
        "drivers": {
            ".read": true,
            ".write": "auth != null",
            ".indexOn": [
                "companyId"
            ]
        },
        "vehicles": {
            ".read": true,
            ".write": "auth != null"
        },
        "pendingjobs": {
            "$companyId": {
                ".read": true,
                "$bookingId": {
                    ".read": true,
                    ".write": "auth != null"
                }
            }
        },
        "bookings": {
            "$companyId": {
                ".read": "auth != null",
                "$bookingId": {
                    ".read": "auth != null",
                    ".write": "auth != null"
                }
            }
        },
        "allbookings": {
            "$companyId": {
                "$bookingId": {
                    ".read": "auth != null",
                    ".write": "auth != null"
                }
            }
        },
        "completedJobs": {
            "$companyId": {
                ".indexOn": ["bookingId"],
                "$bookingId": {
                    ".read": "auth != null",
                    ".write": "auth != null"
                }
            }
        },
        "rideStatus": {
            "$companyId": {
                "$bookingId": {
                    ".read": "auth != null",
                    ".write": "auth != null"
                }
            }
        },
        "autodisp": {
            "$driverId": {
                ".read": true,
                ".write": true
            }
        },
        "jobDetails": {
            "$companyId": {
                ".read": "auth != null",
                ".write": "auth != null"
            }
        },
        "driverQueue": {
            ".read": "auth != null",
            ".write": "auth != null",
            "$companyId": {
                ".validate": "$companyId!='null'",
                "$driverId": {
                    ".validate": "$driverId!='null'",
                    ".read": "auth != null",
                    ".write": "auth != null",
                    "current": {
                        ".validate": "!data.exists() || newData.hasChildren(['jobId'])"
                    },
                    "queued": {
                        ".validate": "!data.exists() || newData.hasChildren(['jobId','acceptedAt'])"
                    }
                }
            }
        },
        "jobCounters": {
            "$companyId": {
                ".read": "auth != null",
                ".write": "auth != null"
            }
        },
